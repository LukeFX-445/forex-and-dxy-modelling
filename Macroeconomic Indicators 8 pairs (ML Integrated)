def calculate_carry_drift(rates_dict):
    carry_drift = {}
    usd_rate = rates_dict.get('USD', 0.0)
    for cur in currencies:
        base_ccy = cur.replace('USD', '').replace('Index', '').replace('_', '')
        if base_ccy and base_ccy in rates_dict:
            carry_drift[cur] = (rates_dict[base_ccy] - usd_rate) / 100.0 / 252.0
        elif cur == 'USD_Index':
            major = [rates_dict.get(c, 0) for c in ['EUR','GBP','JPY','CAD','CHF','AUD'] if c in rates_dict]
            carry_drift[cur] = (usd_rate - np.mean(major)) / 100.0 / 252.0 if major else 0.0
        else:
            carry_drift[cur] = 0.0
    return carry_drift

def calculate_macro_drift(indicators_dict, rates_dict):
    macro_drift = {}
    for cur in currencies:
        base_ccy = cur.replace('USD', '').replace('Index', '').replace('_', '')
        gdp_drift = inf_drift = 0.0
        if f'{base_ccy}_GDP_GROWTH' in indicators_dict and 'USD_GDP_GROWTH' in indicators_dict:
            gdp_drift = ((indicators_dict[f'{base_ccy}_GDP_GROWTH'] -
                          indicators_dict['USD_GDP_GROWTH']) / 100.0) / 252.0 * 0.5
        if f'{base_ccy}_INFLATION' in indicators_dict and 'USD_INFLATION' in indicators_dict:
            inf_drift = ((indicators_dict[f'{base_ccy}_INFLATION'] -
                          indicators_dict['USD_INFLATION']) / 100.0) / 252.0 * 0.3
        macro_drift[cur] = gdp_drift + inf_drift
    return macro_drift

def calculate_sentiment_drift(sentiment_dict):
    sentiment_drift = {}
    for cur in currencies:
        base_ccy = cur.replace('USD', '').replace('Index', '').replace('_', '') or 'USD'
        sent_diff = sentiment_dict.get(base_ccy, 0.0) - sentiment_dict.get('USD', 0.0)
        sentiment_drift[cur] = sent_diff * 0.0002
    return sentiment_drift

def calculate_technical_drift(tech_dict):
    technical_drift = {}
    for cur in currencies:
        if cur not in tech_dict:
            technical_drift[cur] = 0.0
            continue
        ind = tech_dict[cur]
        mom_drift = (ind['momentum_5d']*0.5 + ind['momentum_20d']*0.3 + ind['momentum_60d']*0.2) * 0.1
        rsi = ind['rsi_14']
        rsi_drift = -0.0001 if rsi > 70 else (0.0001 if rsi < 30 else 0.0)
        bb_drift = (ind['bb_position'] - 0.5) * 0.0001
        technical_drift[cur] = mom_drift + rsi_drift - bb_drift
    return technical_drift


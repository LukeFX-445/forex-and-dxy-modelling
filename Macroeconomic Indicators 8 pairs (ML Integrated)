def simulate_prices_advanced(initial_price, drift, vol, regime_vol_adjust, days=1, trials=5000,
                              jump_prob=0.01, jump_mean=0, jump_std=0.02):
    """
    Advanced GBM + Jump-Diffusion simulation with Student-t shocks.
    Seed is set once before the outer loop — not inside this function.
    """
    results = []
    for _ in range(trials):
        price = initial_price
        for t in range(days):
            eps      = stats.t.rvs(df=5, size=1)[0] / np.sqrt(5/3)
            jump     = np.random.normal(jump_mean, jump_std) if np.random.rand() < jump_prob else 0
            vol_adj  = vol * regime_vol_adjust
            price   *= np.exp((drift - 0.5 * vol_adj**2) + vol_adj * eps + jump)
        results.append(price)
    return np.array(results)


# ============================================================================
# SECTION 3: REGIME DETECTION
# FIX[1]: After extracting sigma2 params, ensure regime 0 = low-vol and
# regime 1 = high-vol by swapping vols AND probabilities if needed.
# Without this fix, low_vol_prob and high_vol_prob labels could be inverted,
# misleading downstream volatility blending and ML features.
# ============================================================================

print("\n[3/10] Detecting market regimes...")

regime_states = {}
regime_probs_store = {}  # store full smoothed probability series for ML features

for cur in currencies:
    try:
        ret_series = returns[cur].dropna() * 100

        if len(ret_series) < 100:
            continue

        model = MarkovRegression(ret_series, k_regimes=2, switching_variance=True)
        res = model.fit(maxiter=100, disp=False, warn_convergence=False)

        smoothed_probs = res.smoothed_marginal_probabilities
        current_prob = smoothed_probs.iloc[-1].values

        param_index = list(res.params.index)
        sigma2_keys = [k for k in param_index if 'sigma2' in str(k).lower()]

        if len(sigma2_keys) >= 2:
            vol0 = float(np.sqrt(abs(res.params[sigma2_keys[0]])) / 100)
            vol1 = float(np.sqrt(abs(res.params[sigma2_keys[1]])) / 100)
        else:
            vol0 = float(ret_series.std() / 100) * 0.7
            vol1 = float(ret_series.std() / 100) * 1.3

        # FIX[1]: Ensure regime 0 = low-vol, regime 1 = high-vol.
        # Markov labels are arbitrary — swap vols AND corresponding probabilities
        # if the model assigned higher variance to regime 0.
        if vol0 > vol1:
            vol0, vol1 = vol1, vol0
            current_prob = current_prob[::-1]
            # Also flip the full smoothed series so ML time-series feature is consistent
            smoothed_probs = smoothed_probs.iloc[:, ::-1]
            smoothed_probs.columns = [0, 1]

        regime_states[cur] = {
            'current_regime':  int(np.argmax(current_prob)),
            'low_vol_prob':    float(current_prob[0]),
            'high_vol_prob':   float(current_prob[1]),
            'regime_0_vol':    vol0,
            'regime_1_vol':    vol1,
        }
        # Store the full time series of high-vol probability for ML feature use
        regime_probs_store[cur] = smoothed_probs.iloc[:, 1].reindex(returns.index).ffill()

    except Exception:
        vol_short = ret_series.rolling(20).std()
        vol_long  = ret_series.rolling(60).std()
        is_high   = bool(vol_short.iloc[-1] > vol_long.iloc[-1])
        regime_states[cur] = {
            'current_regime':  1 if is_high else 0,
            'low_vol_prob':    0.3 if is_high else 0.7,
            'high_vol_prob':   0.7 if is_high else 0.3,
            'regime_0_vol':    float(vol_long.iloc[-1] / 100) if not pd.isna(vol_long.iloc[-1]) else 0.01,
            'regime_1_vol':    float(vol_short.iloc[-1] / 100) if not pd.isna(vol_short.iloc[-1]) else 0.02,
        }
        # Fallback: use rolling vol ratio as proxy for high-vol probability time series
        vol_ratio = vol_short / (vol_long + 1e-10)
        regime_probs_store[cur] = vol_ratio.clip(0, 1).reindex(returns.index).ffill().fillna(0.5)

pd.DataFrame(regime_states).T.to_csv('regime_detection.csv')
print(f"✓ Detected regimes for {len(regime_states)} pairs")

# ============================================================================
# SECTION 4: ENHANCED VOLATILITY FORECASTING
# FIX[2]: Previously vol_forecast_enhanced (best GARCH by AIC) was computed
# but never used — vol_forecast_regime always overwrote it. Now we take a
# geometric mean of GARCH and regime vols so both signals contribute.
# ============================================================================

print("\n[4/10] Forecasting volatility with advanced models...")

vol_forecast_simple   = {}
vol_forecast_enhanced = {}
vol_forecast_regime   = {}

for cur in currencies:
    series = returns[cur] * 100

    # Simple GARCH(1,1) Normal as floor estimate
    try:
        am = arch_model(series, vol='Garch', p=1, q=1, dist='normal', rescale=False)
        res = am.fit(disp='off', show_warning=False)
        fcast = res.forecast(horizon=1)
        vol_forecast_simple[cur] = float(np.sqrt(fcast.variance.values[-1, 0]) / 100)
    except Exception:
        vol_forecast_simple[cur] = float(series.std() / 100)

    # Best of GARCH / EGARCH / GJR-GARCH with Student-t, selected by AIC
    try:
        candidates = []
        for spec in [
            dict(vol='Garch',  p=1, q=1,      dist='t'),
            dict(vol='EGARCH', p=1, q=1,      dist='t'),
            dict(vol='Garch',  p=1, o=1, q=1, dist='t'),
        ]:
            try:
                m = arch_model(series, rescale=False, **spec)
                r = m.fit(disp='off', show_warning=False)
                candidates.append(r)
            except Exception:
                pass

        if candidates:
            best  = min(candidates, key=lambda r: r.aic)
            fcast = best.forecast(horizon=1)
            vol_forecast_enhanced[cur] = float(np.sqrt(fcast.variance.values[-1, 0]) / 100)
        else:
            vol_forecast_enhanced[cur] = vol_forecast_simple[cur]
    except Exception:
        vol_forecast_enhanced[cur] = vol_forecast_simple[cur]

    # Regime-weighted vol (probability-weighted blend of regime vols)
    if cur in regime_states:
        rs = regime_states[cur]
        vol_forecast_regime[cur] = (
            rs['low_vol_prob']  * rs['regime_0_vol'] +
            rs['high_vol_prob'] * rs['regime_1_vol']
        )
    else:
        vol_forecast_regime[cur] = vol_forecast_enhanced[cur]

# FIX[2]: Final vol = geometric mean of GARCH-enhanced and regime-weighted.
# Geometric mean prevents either signal from dominating and keeps the estimate
# inside a sensible range when one source is extreme.
volatility_final = {}
for cur in currencies:
    g = vol_forecast_enhanced.get(cur, vol_forecast_simple.get(cur, 0.01))
    r = vol_forecast_regime.get(cur, g)
    # Geometric mean: sqrt(garch * regime)
    volatility_final[cur] = float(np.sqrt(g * r)) if (g > 0 and r > 0) else max(g, r, 1e-4)

pd.DataFrame({
    'simple':        vol_forecast_simple,
    'enhanced_garch': vol_forecast_enhanced,
    'regime_weighted': vol_forecast_regime,
    'final':         volatility_final
}).to_csv('volatility_forecasts.csv')


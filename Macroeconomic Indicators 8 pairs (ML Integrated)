def simulate_prices_advanced(initial_price, drift, vol, days=1, trials=5000,
                              jump_prob=0.02, jump_mean=0, jump_std=0.03):
    """
    GBM + Jump-Diffusion with Student-t shocks.
    Vol is already regime-adjusted (geometric mean of GARCH + regime).
    Seed set once before the outer loop — not here.
    """
    results = []
    for _ in range(trials):
        price = initial_price
        for _ in range(days):
            eps   = stats.t.rvs(df=5, size=1)[0] / np.sqrt(5/3)
            jump  = np.random.normal(jump_mean, jump_std) if np.random.rand() < jump_prob else 0
            price *= np.exp((drift - 0.5 * vol**2) + vol * eps + jump)
        results.append(price)
    return np.array(results)


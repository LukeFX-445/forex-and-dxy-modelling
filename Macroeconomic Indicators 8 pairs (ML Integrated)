            jump_prob=0.02, jump_mean=0, jump_std=0.03
        )

        returns_sim   = (final_prices / P0 - 1.0) * 100
        p5_threshold  = np.percentile(returns_sim, 5)
        tail_returns  = returns_sim[returns_sim <= p5_threshold]
        cvar_95       = float(-np.mean(tail_returns)) if len(tail_returns) > 0 else float(-p5_threshold)

        sim_results[horizon_name][cur] = {
            'mean_return':        float(np.mean(returns_sim)),
            'median_return':      float(np.median(returns_sim)),
            'std_return':         float(np.std(returns_sim)),

        dir_acc   = float(np.mean(np.sign(oof_preds[valid]) == np.sign(y[valid])))

        # Final model on full dataset (no eval_set needed — train to convergence)
        final_params = {k: v for k, v in XGB_PARAMS.items() if k != 'early_stopping_rounds'}
        final_model  = XGBRegressor(**final_params)

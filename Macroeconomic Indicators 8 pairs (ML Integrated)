def calculate_sharpe_ratio(mean_ret, std_ret, risk_free_rate=0.0):
    return 0.0 if std_ret == 0 else (mean_ret - risk_free_rate) / std_ret

def calculate_sortino_ratio(returns_arr, target_return=0.0):
    downside = returns_arr[returns_arr < target_return]
    if len(downside) == 0:
        return 10.0   # FIX[8]: cap instead of inf
    dstd = np.std(downside)
    if dstd == 0:
        return 0.0
    raw = (np.mean(returns_arr) - target_return) / dstd
    return float(min(raw, 10.0))   # FIX[8]: cap

def calculate_omega_ratio(returns_arr, threshold=0.0):
    gains  = returns_arr[returns_arr > threshold] - threshold
    losses = threshold - returns_arr[returns_arr <= threshold]
    if len(losses) == 0:
        return 10.0   # FIX[8]: cap instead of inf
    if len(gains)  == 0:
        return 0.0
    raw = float(np.sum(gains) / np.sum(losses))
    return min(raw, 10.0)   # FIX[8]: cap


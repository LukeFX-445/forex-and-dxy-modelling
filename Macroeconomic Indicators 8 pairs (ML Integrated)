from xgboost import XGBRegressor
from sklearn.model_selection import TimeSeriesSplit
from sklearn.metrics import mean_absolute_error

def build_feature_matrix(cur, closes_df, returns_df, interest_rates_dict,
                          economic_indicators_dict, sentiment_dict, regime_states_dict):
    """
    Build a daily feature matrix for one currency pair combining:
      - Price history:   lagged returns (1,2,3,5,10,20d), rolling vol (5,20d),
                         RSI-14, BB position, momentum (5,20,60d), ATR-normalised
      - VADER sentiment: current compound score for base and USD currencies
      - Fundamentals:    interest rate differential, inflation differential,
                         GDP growth differential (broadcast as time-invariant scalars)
      - Regime:          current high-vol probability
    Target: 5-day forward log return (next week)
    """
    price = closes_df[cur].dropna()
    ret   = returns_df[cur].dropna()

    df = pd.DataFrame(index=ret.index)

    # ── Price history features ──────────────────────────────────────────────
    for lag in [1, 2, 3, 5, 10, 20]:
        df[f'ret_lag{lag}'] = ret.shift(lag)

    df['vol_5d']  = ret.rolling(5).std()
    df['vol_20d'] = ret.rolling(20).std()
    df['vol_ratio'] = df['vol_5d'] / (df['vol_20d'] + 1e-8)

    for w in [5, 20, 60]:
        df[f'mom_{w}d'] = ret.rolling(w).mean()

    # RSI-14
    delta = price.diff()
    gain  = delta.where(delta > 0, 0).rolling(14).mean()
    loss  = (-delta.where(delta < 0, 0)).rolling(14).mean()
    df['rsi_14'] = 100 - (100 / (1 + gain / (loss + 1e-8)))

    # Bollinger Band % position
    sma20 = price.rolling(20).mean()
    std20 = price.rolling(20).std()
    df['bb_pos'] = (price - (sma20 - 2*std20)) / (4*std20 + 1e-8)

    # ── VADER sentiment (broadcast scalar — same for all rows) ───────────────
    base_ccy = cur.replace('USD','').replace('Index','').replace('_','') or 'USD'
    df['sent_base'] = sentiment_dict.get(base_ccy, 0.0)
    df['sent_usd']  = sentiment_dict.get('USD', 0.0)
    df['sent_diff'] = df['sent_base'] - df['sent_usd']

    # ── Macro / fundamental features (broadcast scalars) ────────────────────
    usd_rate = interest_rates_dict.get('USD', 0.0)
    base_rate = interest_rates_dict.get(base_ccy, usd_rate)
    df['rate_diff'] = (base_rate - usd_rate) / 100.0

    usd_inf  = economic_indicators_dict.get('USD_INFLATION', 0.0)
    base_inf = economic_indicators_dict.get(f'{base_ccy}_INFLATION', usd_inf)
    df['inf_diff'] = (base_inf - usd_inf) / 100.0

    usd_gdp  = economic_indicators_dict.get('USD_GDP_GROWTH', 0.0)
    base_gdp = economic_indicators_dict.get(f'{base_ccy}_GDP_GROWTH', usd_gdp)

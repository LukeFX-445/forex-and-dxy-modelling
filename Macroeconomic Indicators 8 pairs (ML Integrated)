    df['high_vol_prob'] = regime_states_dict.get(cur, {}).get('high_vol_prob', 0.5)

    # ── Target: 5-day forward log return ────────────────────────────────────
    df['target_5d'] = ret.shift(-5).rolling(5).sum()

    df = df.dropna()
    return df


# ============================================================================
# SECTION 9A: XGBOOST ML — UNIFIED FEATURE MATRIX
#
# FIX[3]: CRITICAL — corrected target definition.
#   WRONG:  ret.shift(-5).rolling(5).sum()  → days t+5 to t+9 (next-next week)
#   CORRECT: ret.rolling(5).sum().shift(-5)  → days t+1 to t+5 (next week)
#
# FIX[4]: Macro fundamentals (rate_diff, inf_diff, gdp_diff) were static scalars
#   with zero variance across training rows, giving XGBoost nothing to learn.
#   They are now REMOVED from training features and applied as a post-model
#   adjustment to blended_drift so they still influence the final forecast
#   without polluting the ML training signal.
#
# FIX[5]: Same fix applied to VADER sentiment — removed from training features,
#   retained in the analytical drift layer where it belongs.
#
# FIX[6]: high_vol_prob replaced with the full time-varying smoothed probability
#   series from regime_probs_store, giving XGBoost a meaningful temporal feature.
#
# FIX[7]: early_stopping_rounds=30 added to XGBRegressor so eval_set actually
#   triggers early stopping during cross-validation folds.
# ============================================================================

print("\n[9A/10] Training XGBoost models (price history + time-varying regime)...")

def build_feature_matrix(cur, closes_df, returns_df, regime_probs_ts):
    """
    Feature matrix using ONLY time-varying features so every training row
    has genuine signal variance. Static scalars (macro, sentiment) are
    excluded here and applied as post-model drift adjustments instead.

    Features:
      - Lagged log returns: 1, 2, 3, 5, 10, 20 days
      - Rolling volatility: 5d, 20d, and their ratio (vol regime proxy)
      - Momentum: rolling mean return over 5, 20, 60 days
      - RSI-14 (normalised to 0-1)
      - Bollinger Band % position
      - Price vs SMA-20 and SMA-60 (mean-reversion signal)
      - Time-varying high-vol probability from Markov model [FIX[6]]
      - Cross-currency USD strength: mean of all other pairs' returns on same day

    Target: 5-day forward cumulative log return [FIX[3]]
    """
    price = closes_df[cur].dropna()
    ret   = returns_df[cur].dropna()

    df = pd.DataFrame(index=ret.index)

    # Lagged returns
    for lag in [1, 2, 3, 5, 10, 20]:
        df[f'ret_lag{lag}'] = ret.shift(lag)

    # Rolling volatility
    df['vol_5d']    = ret.rolling(5).std()
    df['vol_20d']   = ret.rolling(20).std()
    df['vol_60d']   = ret.rolling(60).std()
    df['vol_ratio'] = df['vol_5d'] / (df['vol_20d'] + 1e-10)

    # Momentum
    for w in [5, 20, 60]:
        df[f'mom_{w}d'] = ret.rolling(w).mean()

    # RSI-14 (normalised to 0-1 for XGBoost stability)
    delta = price.diff()
    gain  = delta.where(delta > 0, 0).rolling(14).mean()
    loss  = (-delta.where(delta < 0, 0)).rolling(14).mean()
    rsi_raw = 100 - (100 / (1 + gain / (loss + 1e-10)))
    df['rsi_norm'] = (rsi_raw / 100.0).reindex(df.index)

    # Bollinger Band % position
    sma20 = price.rolling(20).mean()
    std20 = price.rolling(20).std()
    df['bb_pos'] = ((price - (sma20 - 2*std20)) / (4*std20 + 1e-10)).reindex(df.index)

    # Price vs moving averages (mean-reversion signal)
    for w in [20, 60]:
        sma = price.rolling(w).mean()
        df[f'price_vs_sma{w}'] = ((price - sma) / (sma + 1e-10)).reindex(df.index)

    # FIX[6]: Time-varying regime probability (not a static scalar)
    if regime_probs_ts is not None:
        df['high_vol_prob'] = regime_probs_ts.reindex(df.index).ffill().fillna(0.5)
    else:
        df['high_vol_prob'] = 0.5

    # Cross-currency USD factor: mean of other pairs' returns on same day
    other_rets = [returns_df[c] for c in currencies if c != cur and c in returns_df.columns]
    if other_rets:
        df['usd_factor'] = pd.concat(other_rets, axis=1).mean(axis=1).reindex(df.index)
    else:
        df['usd_factor'] = 0.0

    # FIX[3]: Correct target — cumulative log return over next 5 days
    # rolling(5).sum() accumulates 5 days, shift(-5) aligns to today
    df['target_5d'] = ret.rolling(5).sum().shift(-5)

    df = df.replace([np.inf, -np.inf], np.nan).dropna()
    return df



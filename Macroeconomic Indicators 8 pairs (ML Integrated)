def calculate_sharpe_ratio(mean_ret, std_ret, risk_free_rate=0.0):
    return 0.0 if std_ret == 0 else (mean_ret - risk_free_rate) / std_ret

def calculate_sortino_ratio(returns_sim, target_return=0.0):
    downside = returns_sim[returns_sim < target_return]
    if len(downside) == 0:
        return float('inf')
    dstd = np.std(downside)
    return 0.0 if dstd == 0 else (np.mean(returns_sim) - target_return) / dstd

def calculate_omega_ratio(returns_sim, threshold=0.0):
    gains  = returns_sim[returns_sim > threshold] - threshold
    losses = threshold - returns_sim[returns_sim <= threshold]
    if len(losses) == 0: return float('inf')
    if len(gains)  == 0: return 0.0
    return float(np.sum(gains) / np.sum(losses))


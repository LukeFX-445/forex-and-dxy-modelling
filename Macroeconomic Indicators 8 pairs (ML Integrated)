print("\n[7/10] Computing momentum and technical indicators...")

def compute_technical_indicators(prices, returns_data):
    indicators = {}

    for cur in currencies:
        if cur not in prices.columns:
            continue

        price_series = prices[cur].dropna()
        ret_series = returns_data[cur].dropna()

        mom_5d  = float(ret_series.tail(5).mean())  if len(ret_series) >= 5  else 0.0
        mom_20d = float(ret_series.tail(20).mean()) if len(ret_series) >= 20 else 0.0
        mom_60d = float(ret_series.tail(60).mean()) if len(ret_series) >= 60 else 0.0

        try:
            delta = price_series.diff()
            gain = delta.where(delta > 0, 0).rolling(14).mean()
            loss = (-delta.where(delta < 0, 0)).rolling(14).mean()
            rsi = float(100 - (100 / (1 + gain.iloc[-1] / loss.iloc[-1])))
        except:
            rsi = 50.0

        try:
            sma_20 = price_series.rolling(20).mean()
            std_20 = price_series.rolling(20).std()
            bb_upper = sma_20 + 2 * std_20
            bb_lower = sma_20 - 2 * std_20
            bb_position = float((price_series.iloc[-1] - bb_lower.iloc[-1]) /
                                (bb_upper.iloc[-1] - bb_lower.iloc[-1]))
        except:
            bb_position = 0.5

        try:
            _fallback = usd_index_ticker if usd_index_ticker else 'EURUSD=X'
            high = data_raw['High'][tickers.get(
                cur.replace('USD', '').replace('Index', '').replace('_', ''), _fallback)]
            low  = data_raw['Low'][tickers.get(
                cur.replace('USD', '').replace('Index', '').replace('_', ''), _fallback)]
            tr = pd.concat([high - low,
                            abs(high - price_series.shift(1)),
                            abs(low  - price_series.shift(1))], axis=1).max(axis=1)
            trend_strength = float(tr.rolling(14).mean().iloc[-1] / price_series.iloc[-1])
        except:
            trend_strength = 0.01

        indicators[cur] = {
            'momentum_5d': mom_5d, 'momentum_20d': mom_20d, 'momentum_60d': mom_60d,
            'rsi_14': rsi, 'bb_position': bb_position, 'trend_strength': trend_strength
        }

    return indicators


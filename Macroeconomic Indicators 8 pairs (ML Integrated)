            print(f"  {cur}: insufficient data for ML ({len(feat_df)} rows), skipping")
            ml_drift[cur] = total_drift[cur]
            continue

        feature_cols = [c for c in feat_df.columns if c != 'target_5d']
        X = feat_df[feature_cols].values
        y = feat_df['target_5d'].values

        # ── Walk-forward cross-validation (time-series safe) ────────────────
        tscv = TimeSeriesSplit(n_splits=5)
        oof_preds = np.full(len(y), np.nan)

        for train_idx, val_idx in tscv.split(X):
            X_tr, X_val = X[train_idx], X[val_idx]
            y_tr, y_val = y[train_idx], y[val_idx]

            model_cv = XGBRegressor(
                n_estimators=300,
                max_depth=4,
                learning_rate=0.03,
                subsample=0.8,
                colsample_bytree=0.8,
                min_child_weight=5,
                reg_alpha=0.1,
                reg_lambda=1.0,
                random_state=42,
                verbosity=0
            )
            model_cv.fit(X_tr, y_tr,
                         eval_set=[(X_val, y_val)],
                         verbose=False)
            oof_preds[val_idx] = model_cv.predict(X_val)

        valid_mask = ~np.isnan(oof_preds)
        mae_cv  = mean_absolute_error(y[valid_mask], oof_preds[valid_mask])
        rmse_cv = float(np.sqrt(mean_squared_error(y[valid_mask], oof_preds[valid_mask])))
        dir_acc = float(np.mean(np.sign(oof_preds[valid_mask]) == np.sign(y[valid_mask])))

        # ── Final model trained on all data ─────────────────────────────────
        final_model = XGBRegressor(
            n_estimators=300,
            max_depth=4,
            learning_rate=0.03,
            subsample=0.8,
            colsample_bytree=0.8,
            min_child_weight=5,
            reg_alpha=0.1,
            reg_lambda=1.0,
            random_state=42,
            verbosity=0
        )
        final_model.fit(X, y, verbose=False)

        # ── Predict on the most recent row (today's features) ───────────────
        latest_features = feat_df[feature_cols].iloc[-1:].values
        pred_5d_return  = float(final_model.predict(latest_features)[0])
        # Convert 5-day cumulative prediction to a daily drift
        ml_drift[cur] = pred_5d_return / 5.0

        # ── Feature importances ─────────────────────────────────────────────
        importance = dict(zip(feature_cols, final_model.feature_importances_))
        ml_features[cur] = dict(sorted(importance.items(), key=lambda x: -x[1])[:10])

        ml_models[cur]  = final_model
        ml_metrics[cur] = {
            'mae_cv': round(mae_cv, 6),
            'rmse_cv': round(rmse_cv, 6),
            'dir_accuracy_cv': round(dir_acc, 4),
            'n_samples': len(feat_df),
            'pred_5d_return': round(pred_5d_return, 6),
            'ml_daily_drift': round(ml_drift[cur], 7)
        }

        print(f"  {cur}: MAE={mae_cv:.5f}  DirAcc={dir_acc:.1%}  "
              f"Pred5d={pred_5d_return*100:.3f}%")

    except Exception as e:
        print(f"  {cur}: ML training failed ({e}), falling back to analytical drift")
        ml_drift[cur] = total_drift[cur]
        ml_metrics[cur] = {'error': str(e)}


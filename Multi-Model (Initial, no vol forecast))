def download_with_fallback(ticker_info):
    """Download data with fallback to backup ticker"""
    for attempt in [ticker_info["primary"], ticker_info["backup"]]:
        try:
            data = yf.download(attempt, start=START_DATE, end=END_DATE, 
                             progress=False, auto_adjust=False)
            if isinstance(data.columns, pd.MultiIndex):
                data = data.xs(attempt, axis=1, level=1)
            if not data.empty and len(data) > 200:
                return data, attempt
        except:
            continue
    return pd.DataFrame(), None

def collect_all_data():
    """Collect asset and indicator data"""
    print("\n📊 Collecting market data...")
    
    asset_data = {}
    successful_tickers = {}
    
    for symbol, info in OANDA_MAPPING.items():
        data, used_ticker = download_with_fallback(info)
        if not data.empty:
            asset_data[symbol] = data
            successful_tickers[symbol] = used_ticker
            print(f"✓ {symbol} ({info['name']}): {used_ticker}")
    
    indicator_data = {}
    for ticker, name in INDICATORS.items():
        try:
            data = yf.download(ticker, start=START_DATE, end=END_DATE,
                             progress=False, auto_adjust=False)
            if isinstance(data.columns, pd.MultiIndex):
                data = data.xs(ticker, axis=1, level=1)
            if not data.empty:
                indicator_data[ticker] = data
        except:
            continue
    
    return asset_data, indicator_data, successful_tickers


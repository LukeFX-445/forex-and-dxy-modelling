def calculate_technical_features(data):
    """Calculate comprehensive technical indicators"""
    df = pd.DataFrame(index=data.index)
    close = data['Close']
    high = data['High']
    low = data['Low']
    volume = data['Volume'] if 'Volume' in data else pd.Series(0, index=data.index)
    
    # Returns
    for period in [1, 2, 3, 5, 10, 20, 60]:
        df[f'return_{period}d'] = close.pct_change(period)
        df[f'log_return_{period}d'] = np.log(close / close.shift(period))
    
    # Moving Averages
    for window in [5, 10, 20, 50, 100, 200]:
        sma = close.rolling(window).mean()
        df[f'sma_{window}'] = sma
        df[f'price_to_sma_{window}'] = close / sma
        df[f'sma_{window}_slope'] = sma.diff(5)
    
    # EMA
    for span in [12, 26, 50]:
        ema = close.ewm(span=span).mean()
        df[f'ema_{span}'] = ema
        df[f'price_to_ema_{span}'] = close / ema
    
    # RSI
    for period in [7, 14, 21, 28]:
        delta = close.diff()
        gain = delta.clip(lower=0).rolling(period).mean()
        loss = -delta.clip(upper=0).rolling(period).mean()
        rs = gain / loss.replace(0, np.nan)
        df[f'rsi_{period}'] = 100 - (100 / (1 + rs))
    
    # MACD
    ema12 = close.ewm(span=12).mean()
    ema26 = close.ewm(span=26).mean()
    df['macd'] = ema12 - ema26
    df['macd_signal'] = df['macd'].ewm(span=9).mean()
    df['macd_hist'] = df['macd'] - df['macd_signal']
    
    # Stochastic
    for period in [14, 21]:
        low_min = low.rolling(period).min()
        high_max = high.rolling(period).max()
        stoch = 100 * (close - low_min) / (high_max - low_min)
        df[f'stoch_{period}'] = stoch
        df[f'stoch_{period}_ma'] = stoch.rolling(3).mean()
    
    # ROC
    for period in [5, 10, 20]:
        df[f'roc_{period}'] = close.pct_change(period) * 100
    
    # Volatility
    for period in [5, 10, 20, 60]:
        df[f'volatility_{period}d'] = close.pct_change().rolling(period).std() * np.sqrt(252)
    
    # Bollinger Bands
    for period in [20, 50]:
        sma = close.rolling(period).mean()
        std = close.rolling(period).std()
        df[f'bb_upper_{period}'] = sma + 2 * std
        df[f'bb_lower_{period}'] = sma - 2 * std
        df[f'bb_width_{period}'] = (df[f'bb_upper_{period}'] - df[f'bb_lower_{period}']) / sma
        df[f'bb_position_{period}'] = (close - df[f'bb_lower_{period}']) / (df[f'bb_upper_{period}'] - df[f'bb_lower_{period}'])
    
    # ATR
    tr = pd.concat([
        high - low,
        (high - close.shift(1)).abs(),
        (low - close.shift(1)).abs()
    ], axis=1).max(axis=1)
    
    for period in [7, 14, 21]:
        df[f'atr_{period}'] = tr.rolling(period).mean()
        df[f'atr_{period}_pct'] = df[f'atr_{period}'] / close
    
    # Volume
    for period in [5, 10, 20]:
        vol_sma = volume.rolling(period).mean()
        df[f'volume_sma_{period}'] = vol_sma
        df[f'volume_ratio_{period}'] = volume / vol_sma
    
    # OBV
    obv = (np.sign(close.diff()) * volume).fillna(0).cumsum()
    df['obv'] = obv
    df['obv_ema'] = obv.ewm(span=20).mean()
    
    # VPT
    df['vpt'] = (volume * close.pct_change()).cumsum()
    
    # Pattern Recognition
    df['higher_high'] = (high > high.shift(1)).astype(int)
    df['higher_low'] = (low > low.shift(1)).astype(int)
    df['uptrend_strength'] = df['higher_high'].rolling(10).sum() + df['higher_low'].rolling(10).sum()
    
    # Channels
    df['channel_high_20'] = high.rolling(20).max()
    df['channel_low_20'] = low.rolling(20).min()
    df['channel_position'] = (close - df['channel_low_20']) / (df['channel_high_20'] - df['channel_low_20'])
    
    # Distance from extremes
    df['dist_from_52w_high'] = (close / high.rolling(252).max() - 1)
    df['dist_from_52w_low'] = (close / low.rolling(252).min() - 1)
    
    # Statistical
    for period in [20, 60]:
        returns = close.pct_change()
        df[f'return_skew_{period}'] = returns.rolling(period).skew()
        df[f'return_kurt_{period}'] = returns.rolling(period).kurt()
        mean = returns.rolling(period).mean()
        std = returns.rolling(period).std()
        df[f'zscore_{period}'] = (returns - mean) / std
    
    # Crosses
    df['sma_cross_50_200'] = df['sma_50'] - df['sma_200']
    df['ema_cross_12_26'] = df['ema_12'] - df['ema_26']
    
    return df.replace([np.inf, -np.inf], np.nan)

def calculate_macro_features(indicator_data):
    """Calculate macroeconomic features"""
    macro = {}
    
    # VIX features
    if '^VIX' in indicator_data:
        vix = indicator_data['^VIX']['Close']
        macro['vix'] = float(vix.iloc[-1])
        macro['vix_sma_20'] = float(vix.rolling(20).mean().iloc[-1])
        macro['vix_change'] = float(vix.pct_change().iloc[-1])
        macro['vix_spike'] = float(vix.iloc[-1] > vix.rolling(20).mean().iloc[-1] + vix.rolling(20).std().iloc[-1])
    
    # Treasury yields
    if '^TNX' in indicator_data:
        tnx = indicator_data['^TNX']['Close']
        macro['yield_10y'] = float(tnx.iloc[-1])
        macro['yield_10y_change'] = float(tnx.diff().iloc[-1])
        macro['yield_10y_roc'] = float(tnx.pct_change(20).iloc[-1])
    
    if '^FVX' in indicator_data:
        fvx = indicator_data['^FVX']['Close']
        macro['yield_5y'] = float(fvx.iloc[-1])
    
    if '^IRX' in indicator_data:
        irx = indicator_data['^IRX']['Close']
        macro['yield_3m'] = float(irx.iloc[-1])
    
    # Yield curve
    if '^FVX' in indicator_data and '^TNX' in indicator_data:
        macro['yield_curve_5_10'] = macro.get('yield_5y', 0) - macro.get('yield_10y', 0)
    
    # Dollar
    if 'DX-Y.NYB' in indicator_data:
        dxy = indicator_data['DX-Y.NYB']['Close']
        macro['dxy'] = float(dxy.iloc[-1])
        macro['dxy_return_20d'] = float(dxy.pct_change(20).iloc[-1])
        macro['dxy_sma_50'] = float(dxy.rolling(50).mean().iloc[-1])
    
    # Credit spreads
    if 'HYG' in indicator_data and 'LQD' in indicator_data:
        hyg = indicator_data['HYG']['Close'].pct_change(20).iloc[-1]
        lqd = indicator_data['LQD']['Close'].pct_change(20).iloc[-1]
        macro['credit_spread_proxy'] = float(hyg - lqd)
    
    # Market breadth
    if '^GSPC' in indicator_data and 'IWM' in indicator_data:
        spy_ret = indicator_data['^GSPC']['Close'].pct_change(20).iloc[-1]
        iwm_ret = indicator_data['IWM']['Close'].pct_change(20).iloc[-1]
        macro['large_vs_small_cap'] = float(spy_ret - iwm_ret)
    
    # Bitcoin
    if 'BTC-USD' in indicator_data:
        btc = indicator_data['BTC-USD']['Close']
        macro['btc_momentum'] = float(btc.pct_change(20).iloc[-1])
    
    # Sectors
    for sector, ticker in [('XLE', 'XLE'), ('XLF', 'XLF'), ('XLK', 'XLK')]:
        if ticker in indicator_data:
            ret = indicator_data[ticker]['Close'].pct_change(20).iloc[-1]
            macro[f'{sector}_momentum'] = float(ret)
    
    return macro

def fit_regime_model(returns, n_regimes=3):
    """Fit Markov regime-switching model"""
    try:
        r = (returns.dropna() * 100).values
        idx = returns.dropna().index
        
        model = MarkovRegression(r, k_regimes=n_regimes, switching_variance=True)
        res = model.fit(disp=False, maxiter=100, warn_convergence=False)
        
        probs = res.smoothed_marginal_probabilities
        regime_df = pd.DataFrame({
            f'regime_{i}_prob': probs[i] for i in range(n_regimes)
        }, index=idx)
        
        regime_df['regime_current'] = regime_df.idxmax(axis=1).str.extract('(\d+)').astype(int)
        
        # Extract regime volatilities
        for i in range(n_regimes):
            try:
                regime_df[f'regime_{i}_vol'] = float(np.sqrt(res.params[f'sigma2[{i}]']) / 100)
            except:
                regime_df[f'regime_{i}_vol'] = 0.01
        
        return regime_df
    except:
        # Fallback: simple volatility-based regimes
        vol = returns.rolling(20).std()
        vol_z = (vol - vol.rolling(60).mean()) / vol.rolling(60).std()
        regime = pd.cut(vol_z, [-np.inf, -0.5, 0.5, np.inf], labels=[0, 1, 2]).astype(float)
        
        regime_df = pd.DataFrame({'regime_current': regime}, index=returns.index)
        for i in range(n_regimes):
            regime_df[f'regime_{i}_prob'] = (regime == i).astype(float)
            regime_df[f'regime_{i}_vol'] = 0.01
        
        return regime_df


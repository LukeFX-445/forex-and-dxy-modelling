def train_ensemble_model(X, y):
    """Train ensemble of ML models"""
    scaler = RobustScaler()
    X_scaled = pd.DataFrame(scaler.fit_transform(X), index=X.index, columns=X.columns)
    
    models = {
        'LR': LogisticRegression(max_iter=2000, class_weight='balanced', random_state=SEED),
        'RF': RandomForestClassifier(n_estimators=300, max_depth=20, min_samples_split=10,
                                    class_weight='balanced', n_jobs=-1, random_state=SEED),
        'GB': GradientBoostingClassifier(n_estimators=300, max_depth=5, learning_rate=0.03,
                                        subsample=0.8, random_state=SEED),
        'XGB': xgb.XGBClassifier(n_estimators=200, max_depth=6, learning_rate=0.05,
                                subsample=0.8, eval_metric='logloss', random_state=SEED),
        'LGB': lgb.LGBMClassifier(n_estimators=200, max_depth=6, learning_rate=0.05,
                                 subsample=0.8, random_state=SEED, verbose=-1)
    }
    
    # Time series cross-validation
    tscv = TimeSeriesSplit(n_splits=5)
    scores = {}
    trained_models = {}
    
    for name, model in models.items():
        fold_scores = []
        for train_idx, val_idx in tscv.split(X_scaled):
            try:
                model.fit(X_scaled.iloc[train_idx], y.iloc[train_idx])
                pred = model.predict(X_scaled.iloc[val_idx])
                fold_scores.append(accuracy_score(y.iloc[val_idx], pred))
            except:
                break
        
        if fold_scores:
            scores[name] = np.mean(fold_scores)
            trained_models[name] = model
    
    if len(trained_models) >= 3:
        # Create voting ensemble
        ensemble = VotingClassifier(
            estimators=[(name, trained_models[name]) for name in trained_models],
            voting='soft'
        )
        ensemble.fit(X_scaled, y)
        trained_models['ENSEMBLE'] = ensemble
        scores['ENSEMBLE'] = max(scores.values()) + 0.01
    
    best_name = max(scores, key=scores.get)
    
    return {
        'scaler': scaler,
        'best_model': trained_models[best_name],
        'best_name': best_name,
        'cv_score': scores[best_name],
        'all_scores': scores
    }


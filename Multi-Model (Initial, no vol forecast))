def run_forecasting_system():
    print("\n" + "="*80)
    print("🎯 OANDA MULTI-ASSET FORECASTING SYSTEM")
    print("="*80)
    
    # Collect data
    asset_data, indicator_data, tickers_used = collect_all_data()
    
    if not asset_data:
        print("❌ No data collected. Exiting.")
        return
    
    # Process each asset
    results = {}
    
    for symbol, data in asset_data.items():
        print(f"\n📈 Processing {symbol} ({OANDA_MAPPING[symbol]['name']})...")
        
        # Calculate features
        tech_features = calculate_technical_features(data)
        macro_features = calculate_macro_features(indicator_data)
        
        # Calculate returns and regimes
        returns = data['Close'].pct_change()
        regime_features = fit_regime_model(returns)
        
        # Combine features
        features = tech_features.copy()
        for key, value in macro_features.items():
            features[f'macro_{key}'] = value
        
        features = pd.concat([features, regime_features.reindex(features.index)], axis=1)
        
        # Create target (3-day forward return direction)
        target_returns = data['Close'].pct_change(FORECAST_HORIZON).shift(-FORECAST_HORIZON)
        target = (target_returns > 0).astype(int)
        
        # Prepare training data
        combined = pd.concat([features, target.rename('target')], axis=1).dropna()
        
        if len(combined) < 500:
            print(f"⚠️  Insufficient data for {symbol}")
            continue
        
        X = combined.drop('target', axis=1)
        y = combined['target']
        
        # Fill any remaining NaNs
        X = X.fillna(X.median())
        
        # Train model
        try:
            model_result = train_ensemble_model(X, y)
            
            # Make prediction on latest data
            latest_features = X.iloc[-1:].copy()
            latest_scaled = model_result['scaler'].transform(latest_features)
            
            prediction = int(model_result['best_model'].predict(latest_scaled)[0])
            proba = model_result['best_model'].predict_proba(latest_scaled)[0]
            
            confidence = float(proba.max())
            prob_up = float(proba[1])
            prob_down = float(proba[0])
            
            # Calculate additional metrics
            current_price = float(data['Close'].iloc[-1])
            recent_return = float(returns.tail(20).mean() * 100)
            volatility = float(returns.tail(60).std() * np.sqrt(252) * 100)
            current_regime = int(regime_features['regime_current'].iloc[-1])
            
            results[symbol] = {
                'name': OANDA_MAPPING[symbol]['name'],
                'ticker_used': tickers_used[symbol],
                'current_price': current_price,
                'prediction': 'BULLISH' if prediction == 1 else 'BEARISH',
                'confidence': confidence,
                'prob_bullish': prob_up,
                'prob_bearish': prob_down,
                'signal_strength': abs(prob_up - prob_down),
                'model_accuracy': model_result['cv_score'],
                'model_used': model_result['best_name'],
                'recent_momentum': recent_return,
                'volatility_annual': volatility,
                'regime': ['Bull (Low Vol)', 'Normal', 'Bear (High Vol)'][current_regime],
                'regime_code': current_regime
            }
            
            print(f"✓ Prediction: {results[symbol]['prediction']} (confidence: {confidence:.1%})")
            
        except Exception as e:
            print(f"❌ Model training failed for {symbol}: {e}")
            continue
    
    # Rank opportunities
    if not results:
        print("\n❌ No successful predictions. Exiting.")
        return
    
    # Calculate composite score
    for symbol in results:
        r = results[symbol]
        
        # Score components:
        # 1. Signal strength (probability differential)
        # 2. Model confidence
        # 3. Model accuracy
        # 4. Favorable regime (bull = higher score)
        
        regime_bonus = 0.1 if r['regime_code'] == 0 else (-0.1 if r['regime_code'] == 2 else 0)
        
        r['composite_score'] = (
            r['signal_strength'] * 0.4 +
            r['confidence'] * 0.3 +
            r['model_accuracy'] * 0.2 +
            regime_bonus
        )
    
    # Sort by composite score
    ranked = sorted(results.items(), key=lambda x: x[1]['composite_score'], reverse=True)
    
    # Display results
    print("\n" + "="*80)
    print("🏆 TOP 2 TRADING OPPORTUNITIES (48-72 Hour Forecast)")
    print("="*80)
    
    for i, (symbol, r) in enumerate(ranked[:2], 1):
        print(f"\n#{i}. {symbol} ({r['name']})")
        print(f"    Direction: {r['prediction']}")
        print(f"    Confidence: {r['confidence']:.1%}")
        print(f"    Signal Strength: {r['signal_strength']:.1%}")
        print(f"    Model Accuracy: {r['model_accuracy']:.1%}")
        print(f"    Current Price: ${r['current_price']:.2f}")
        print(f"    Recent Momentum: {r['recent_momentum']:+.2f}%")
        print(f"    Volatility (Annual): {r['volatility_annual']:.1f}%")
        print(f"    Market Regime: {r['regime']}")
        print(f"    Model Used: {r['model_used']}")
        print(f"    Ticker: {r['ticker_used']}")
    
    print("\n" + "="*80)
    print("📊 ALL ASSET RANKINGS")
    print("="*80)
    
    for i, (symbol, r) in enumerate(ranked, 1):
        direction_emoji = "🟢" if r['prediction'] == 'BULLISH' else "🔴"
        print(f"{i}. {direction_emoji} {symbol:15s} {r['prediction']:8s} | "
              f"Conf: {r['confidence']:.1%} | Score: {r['composite_score']:.3f}")
    
    # Save results
    results_df = pd.DataFrame(results).T
    results_df.to_csv('oanda_forecast_results.csv')
    
    print(f"\n✅ Results saved to 'oanda_forecast_results.csv'")
    print("\n⚠️  DISCLAIMER: For educational purposes only. Not financial advice.")


    macro_data               = collect_macro_data()

    print("\nFetching interest rates...")
    interest_rates = fetch_interest_rates()

    print("\nFetching sentiment...")
    sentiments = fetch_news_sentiments()
    print(f"  Sentiment: { {k: round(v, 3) for k, v in sentiments.items()} }")

    macro_features = calculate_macro_features(macro_data)

    if not asset_data:
        print("No asset data collected. Exiting.")
        return

    # -- 2. Per-asset processing -----------------------------------------------
    results = {}
    np.random.seed(SEED)   # single seed; MC functions must not reset internally

    for symbol, data in asset_data.items():
        info = ASSET_UNIVERSE[symbol]
        print(f"\n  Processing {symbol} ({info['name']})...")

        close   = data["Close"].squeeze()
        returns = close.pct_change().dropna()

        # -- Technical features ------------------------------------------------
        tech_df = calculate_technical_features(data)

        # Latest snapshot for drift inputs
        rsi_14 = _safe_float(
            tech_df["rsi_14"].dropna().iloc[-1]
            if "rsi_14" in tech_df.columns else 50.0)
        bb_pos = _safe_float(
            tech_df["bb_position_20"].dropna().iloc[-1]
            if "bb_position_20" in tech_df.columns else 0.5)

        # -- Regime detection --------------------------------------------------
        regime_df   = fit_regime_model(returns)
        current_reg = int(regime_df["regime_current"].iloc[-1])

        # Probability-weighted regime volatility across all 3 states
        fallback_v   = float(returns.std())
        regime_adj_v = sum(
            _safe_float(regime_df.get(f"regime_{i}_prob",
                                      pd.Series(1.0 / N_REGIMES)).iloc[-1])
            * _safe_float(regime_df.get(f"regime_{i}_vol",
                                        pd.Series(fallback_v)).iloc[-1])
            for i in range(N_REGIMES)
        )

        # -- GARCH volatility --------------------------------------------------
        garch_vol = forecast_volatility(returns)
        final_vol = max(garch_vol, regime_adj_v)   # conservative: take larger

        # -- Drift -------------------------------------------------------------
        drift_dict  = calculate_drift(symbol, returns, interest_rates,
                                      rsi_14, bb_pos)
        total_drift = drift_dict["total"]

        # -- Sentiment differential for this asset's currency ------------------
        ccy       = ASSET_TO_CCY.get(symbol, "USD")
        sent_diff = (_safe_float(sentiments.get(ccy, 0.0))
                     - _safe_float(sentiments.get("USD", 0.0)))

        # -- ML ensemble -------------------------------------------------------
        # Feature matrix: technical indicators + scalar macro features +
        #                 regime probabilities (all look-back, no leakage).
        # Target: sign of FORECAST_HORIZON-bar-ahead return.
        # shift(-H) aligns target with current bar; combined.dropna() then
        # removes the final H rows that have no resolvable future target.
        features = tech_df.copy()
        for k, v in macro_features.items():
            features[f"macro_{k}"] = v
        features = pd.concat(
            [features, regime_df.reindex(features.index)], axis=1)

        fwd_ret  = close.pct_change(FORECAST_HORIZON).shift(-FORECAST_HORIZON)
        target   = (fwd_ret > 0).astype(int)
        combined = pd.concat(
            [features, target.rename("target")], axis=1).dropna()

        ml_result = {}
        ml_prob_up, ml_cv, ml_name = 0.5, 0.5, "N/A"

        if len(combined) >= 500:
            X_df = combined.drop("target", axis=1)
            y_s  = combined["target"]
            try:
                ml_result = train_ml_ensemble(X_df, y_s)
            except Exception as e:
                print(f"    ML training failed: {e}")

            if ml_result and ml_result.get("best_model") is not None:
                # Live inference row: uses full feature set (including today,
                # which has no future target yet and was excluded from combined).
                # Column alignment in predict_with_model handles any mismatches.
                live_feat = pd.concat(
                    [tech_df, regime_df.reindex(tech_df.index)],
                    axis=1).iloc[-1:]
                for k, v in macro_features.items():
                    live_feat[f"macro_{k}"] = v

                ml_prob_up = predict_with_model(ml_result, live_feat)
                ml_cv      = ml_result["cv_score"]
                ml_name    = ml_result["best_name"]
        else:
            print(f"    Insufficient rows for ML ({len(combined)}); using 0.5")

        # -- Monte Carlo -------------------------------------------------------
        current_price = _safe_float(close.iloc[-1])
        mc = run_monte_carlo(current_price, total_drift, final_vol)

        # -- Risk-adjusted ratios (1-week horizon) -----------------------------
        r1w   = mc["1w"]["ret_array"]
        sr    = _sharpe(mc["1w"]["mean_return"], mc["1w"]["std_return"])
        so    = _sortino(r1w)
        om    = _omega(r1w)
        r2var = (mc["1w"]["mean_return"] / mc["1w"]["VaR_95"]
                 if mc["1w"]["VaR_95"] > 0 else 0.0)

        direction    = "BULLISH" if mc["1w"]["mean_return"] > 0 else "BEARISH"
        ml_direction = "BULLISH" if ml_prob_up > 0.5 else "BEARISH"
        regime_raw   = {0: +1.0, 1: 0.0, 2: -1.0}.get(current_reg, 0.0)

        results[symbol] = {
            "name":               info["name"],
            "asset_class":        info["class"],
            "ticker_used":        tickers_used[symbol],
            "current_price":      current_price,
            "ml_prob_bullish":    ml_prob_up,
            "ml_cv_score":        ml_cv,
            "ml_direction":       ml_direction,
            "ml_model":           ml_name,
            "mc_direction":       direction,
            "mc_prob_up":         mc["1w"]["prob_up"],
            "mc_return_1d":       mc["1d"]["mean_return"],
            "mc_return_1w":       mc["1w"]["mean_return"],
            "mc_return_2w":       mc["2w"]["mean_return"],
            "mc_return_1m":       mc["1m"]["mean_return"],
            "var95_1w":           mc["1w"]["VaR_95"],
            "cvar95_1w":          mc["1w"]["CVaR_95"],
            "range_low_1s":       mc["1w"]["range_low_1s"],
            "range_high_1s":      mc["1w"]["range_high_1s"],
            "garch_vol_daily":    garch_vol,
            "final_vol_daily":    final_vol,
            "ann_vol_pct":        final_vol * 100 * np.sqrt(252),
            "regime":             current_reg,
            "regime_label":       REGIME_LABELS.get(current_reg, "?"),
            "drift_carry":        drift_dict["carry"],
            "drift_momentum":     drift_dict["momentum"],
            "drift_total":        total_drift,
            "sharpe_1w":          sr,
            "sortino_1w":         so,
            "omega_1w":           om,
            "return_to_var":      r2var,
            "sent_diff":          sent_diff,
            "_regime_raw":        regime_raw,
            "signal_aligned":     direction == ml_direction,
            "composite_score":    0.0,   # filled in cross-sectional pass below
            "_mc":                mc,    # excluded from CSV export by _ prefix
        }

        print(f"    MC {direction} ({mc['1w']['mean_return']:+.2f}% 1w) | "
              f"ML {ml_direction} ({ml_prob_up:.0%}) | "
              f"Vol {final_vol*100:.2f}%/d | "
              f"Regime {REGIME_LABELS.get(current_reg)} | "
              f"Sharpe {sr:.2f}")

    # -- 3. Cross-sectional composite score ------------------------------------
    #
    # All scoring components live on different scales:
    #   Sharpe   ~ [-3,  +5]
    #   Sortino  ~ [-5, +20]
    #   Omega    ~ [ 0,  10]  (capped)
    #   R/VaR    ~ [-2,  +2]
    #   ML prob  ~ [ 0,   1]
    #   Sent     ~ [-2,  +2]
    #   Regime   ~ {-1, 0, +1}
    #
    # Fix: z-score each metric across all N assets in the current universe,
    # so every component has mean=0, std=1 before weighting.
    # Weights reflect signal reliability, not scale:
    #   Sortino  25% -- downside-only risk adj, most relevant for directional trades
    #   R/VaR    20% -- reward vs worst-case tail from MC distribution
    #   Sharpe   15% -- overall MC risk-adj quality
    #   ML prob  15% -- independent directional signal from ensemble
    #   Omega    10% -- probability-weighted gain/loss ratio
    #   Sent     10% -- news-flow positioning signal
    #   Regime    5% -- structural context (coarser, lower weight)
    # --------------------------------------------------------------------------

    if not results:
        print("\nNo results to display.")
        return

    SCORE_WEIGHTS = {
        "sortino_1w":      0.25,
        "return_to_var":   0.20,
        "sharpe_1w":       0.15,
        "ml_prob_bullish": 0.15,
        "omega_1w":        0.10,
        "sent_diff":       0.10,
        "_regime_raw":     0.05,
    }

    syms = list(results.keys())

    def _xscore(arr: np.ndarray) -> np.ndarray:
        mu, sd = np.nanmean(arr), np.nanstd(arr)
        return (arr - mu) / sd if sd > 1e-12 else np.zeros_like(arr)

    raw = {k: np.array([results[s][k] for s in syms], dtype=float)
           for k in SCORE_WEIGHTS}

    # Winsorise omega before z-scoring (cap at 99th percentile)
    fin_om = raw["omega_1w"][np.isfinite(raw["omega_1w"])]
    p99    = float(np.nanpercentile(fin_om, 99)) if len(fin_om) > 0 else 10.0
    raw["omega_1w"] = np.clip(raw["omega_1w"], -np.inf, p99)

    composite = np.zeros(len(syms))
    for k, w in SCORE_WEIGHTS.items():
        composite += w * _xscore(raw[k])

    for i, sym in enumerate(syms):
        results[sym]["composite_score"] = float(composite[i])

    ranked = sorted(results.items(),
                    key=lambda x: x[1]["composite_score"], reverse=True)

    # -- 4. Display ------------------------------------------------------------
    print("\n  Cross-sectional composite scores (z-normalised):")
    print(f"  {'Symbol':<18} {'Score':>8}  {'MC Dir':>8}  {'ML Dir':>8}  Regime")
    print("  " + "-" * 60)
    for sym, r in ranked:
        aligned = "ok" if r["signal_aligned"] else "!!"
        print(f"  {sym:<18} {r['composite_score']:>+8.4f}  "
              f"{r['mc_direction']:>8}  {r['ml_direction']:>8}  "
              f"{r['regime_label']}  [{aligned}]")

    print("\n" + "=" * 72)
    print("  TOP 3 OPPORTUNITIES  --  48-72 h Forecast")
    print("=" * 72)
    for i, (sym, r) in enumerate(ranked[:3], 1):
        aligned = "signals aligned" if r["signal_aligned"] else "SIGNALS DIVERGE"
        print(f"""
#{i}  {sym}  ({r['name']})  [{r['asset_class']}]
    MC / ML direction  : {r['mc_direction']} / {r['ml_direction']}  ({aligned})
    Composite score    : {r['composite_score']:+.4f}
    MC prob up (1w)    : {r['mc_prob_up']:.1%}
    Expected return    : 1d {r['mc_return_1d']:+.2f}%  1w {r['mc_return_1w']:+.2f}%  2w {r['mc_return_2w']:+.2f}%  1m {r['mc_return_1m']:+.2f}%
    Risk (1w)          : VaR95 {r['var95_1w']:.2f}%  CVaR95 {r['cvar95_1w']:.2f}%
    Price range (1 sd) : {r['range_low_1s']:.4f}  to  {r['range_high_1s']:.4f}
    Sharpe / Sortino   : {r['sharpe_1w']:.3f} / {r['sortino_1w']:.3f}   Omega: {r['omega_1w']:.3f}
    Ann. volatility    : {r['ann_vol_pct']:.1f}%   (GARCH daily: {r['garch_vol_daily']*100:.2f}%)
    Regime             : {r['regime_label']}
    Drift carry / mom  : {r['drift_carry']*1e4:+.2f} bp/d  /  {r['drift_momentum']*1e4:+.2f} bp/d
    ML model / CV acc  : {r['ml_model']}  ({r['ml_cv_score']:.1%})
    Ticker / price     : {r['ticker_used']}  @  {r['current_price']:.4f}
""")

    print("=" * 72)
    print("  FULL RANKINGS")
    print("=" * 72)
    hdr = (f"  {'#':>2}  {'Symbol':<18} {'Class':<8} {'Dir':<9}"
           f"{'Score':>8}  {'MC-up':>6}  {'SR':>6}  {'SO':>6}  {'Ann-Vol':>8}")
    print(hdr)
    print("  " + "-" * (len(hdr) - 2))
    for i, (sym, r) in enumerate(ranked, 1):
        arrow = "+" if r["mc_direction"] == "BULLISH" else "-"
        print(f"  {i:>2}. {sym:<18} {r['asset_class']:<8} "
              f"{arrow}{r['mc_direction']:<8} "
              f"{r['composite_score']:>+8.4f}  "
              f"{r['mc_prob_up']:>6.1%}  "
              f"{r['sharpe_1w']:>6.2f}  "
              f"{r['sortino_1w']:>6.2f}  "
              f"{r['ann_vol_pct']:>7.1f}%")

    # -- 5. Export CSVs --------------------------------------------------------
    export_rows = []
    for sym, r in results.items():
        row = {k: v for k, v in r.items() if not k.startswith("_")}
        row["symbol"] = sym
        export_rows.append(row)

    pd.DataFrame(export_rows).set_index("symbol").to_csv(
        "oanda_forecast_summary.csv")

    mc_rows = []
    for sym, r in results.items():
        for h, h_stats in r["_mc"].items():
            mc_rows.append({
                "symbol": sym, "horizon": h,
                "mean_return":   h_stats["mean_return"],
                "std_return":    h_stats["std_return"],
                "prob_up":       h_stats["prob_up"],
                "VaR_95":        h_stats["VaR_95"],
                "CVaR_95":       h_stats["CVaR_95"],
                "skew":          h_stats["skew"],
                "kurtosis":      h_stats["kurtosis"],
            })
    pd.DataFrame(mc_rows).to_csv("oanda_forecast_mc_horizons.csv", index=False)

    pd.DataFrame({"rate_%": interest_rates}).to_csv("interest_rates.csv")
    pd.DataFrame({"sentiment": sentiments}).to_csv("sentiments.csv")

    # -- 6. Walk-forward backtest (live backfill on each run) ------------------
    _write_backtest_log(results, asset_data)

    print("\nFiles written:")
    for f in ["oanda_forecast_summary.csv", "oanda_forecast_mc_horizons.csv",
              "interest_rates.csv", "sentiments.csv", BT_FILE]:
        print(f"  {f}")

    print("\nDISCLAIMER: Research / educational use only. Not financial advice.")



def _strip_multiindex(df: pd.DataFrame, ticker: str) -> pd.DataFrame:
    if isinstance(df.columns, pd.MultiIndex):
        try:
            df = df.xs(ticker, axis=1, level=1)
        except KeyError:
            df.columns = df.columns.droplevel(1)
    return df


def download_with_fallback(info: dict):
    candidates = [c for c in [info["primary"], info.get("backup")] if c]
    for ticker in candidates:
        try:
            df = yf.download(ticker, start=START_DATE, end=END_DATE,
                             progress=False, auto_adjust=False)
            df = _strip_multiindex(df, ticker)
            df.columns = [c.strip() for c in df.columns]
            for col in ["Open", "High", "Low", "Close"]:
                if col not in df.columns and "Adj Close" in df.columns:
                    df[col] = df["Adj Close"]
            if "Volume" not in df.columns:
                df["Volume"] = 0
            if not df.empty and len(df) > 200:
                return df, ticker
        except Exception:
            continue
    return pd.DataFrame(), None


def collect_asset_data():
    print("\nCollecting asset data...")
    asset_data, tickers_used = {}, {}
    for symbol, info in ASSET_UNIVERSE.items():
        df, ticker = download_with_fallback(info)
        if not df.empty:
            asset_data[symbol]   = df
            tickers_used[symbol] = ticker
            print(f"  ok  {symbol:20s} ({info['name']:15s}) via {ticker}")
        else:
            print(f"  --  {symbol:20s} -- no data")
    return asset_data, tickers_used



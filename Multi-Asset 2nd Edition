def calculate_technical_features(data: pd.DataFrame) -> pd.DataFrame:
    """
    ~75 purely look-back technical features.
    No look-ahead bias: every feature at bar t uses only data <= t.
    The forward-return target is created separately in the pipeline.
    Features are price-normalised where possible to improve model
    generalisation across assets and price levels.
    """
    df    = pd.DataFrame(index=data.index)
    close = data["Close"].squeeze()
    high  = data["High"].squeeze()
    low   = data["Low"].squeeze()
    vol   = (data["Volume"].squeeze() if "Volume" in data.columns
             else pd.Series(0, index=data.index))

    # Returns
    for p in [1, 2, 3, 5, 10, 20, 60]:
        df[f"return_{p}d"]     = close.pct_change(p)
        df[f"log_return_{p}d"] = np.log(close / close.shift(p))

    # Price-normalised MAs
    for w in [5, 10, 20, 50, 100, 200]:
        sma = close.rolling(w).mean()
        df[f"price_to_sma_{w}"] = close / sma - 1
        df[f"sma_{w}_slope"]    = sma.diff(5) / sma

    for span in [12, 26, 50]:
        ema = close.ewm(span=span).mean()
        df[f"price_to_ema_{span}"] = close / ema - 1

    # MACD (price-normalised)
    ema12 = close.ewm(span=12).mean()
    ema26 = close.ewm(span=26).mean()
    macd  = ema12 - ema26
    df["macd_norm"]        = macd / close
    df["macd_signal_norm"] = macd.ewm(span=9).mean() / close
    df["macd_hist_norm"]   = (macd - macd.ewm(span=9).mean()) / close

    # RSI (multiple periods)
    for p in [7, 14, 21]:
        delta = close.diff()
        gain  = delta.clip(lower=0).rolling(p).mean()
        loss  = (-delta.clip(upper=0)).rolling(p).mean()
        rs    = gain / loss.replace(0, np.nan)
        df[f"rsi_{p}"] = 100 - (100 / (1 + rs))

    # Stochastic
    for p in [14, 21]:
        lo, hi = low.rolling(p).min(), high.rolling(p).max()
        stoch  = 100 * (close - lo) / (hi - lo)
        df[f"stoch_{p}"]    = stoch
        df[f"stoch_{p}_ma"] = stoch.rolling(3).mean()

    # Bollinger Bands
    for p in [20, 50]:
        sma  = close.rolling(p).mean()
        std  = close.rolling(p).std()
        bb_u, bb_l = sma + 2*std, sma - 2*std
        df[f"bb_width_{p}"]    = (bb_u - bb_l) / sma
        df[f"bb_position_{p}"] = (close - bb_l) / (bb_u - bb_l)

    # ATR (price-normalised)
    tr = pd.concat([
        high - low,
        (high - close.shift(1)).abs(),
        (low  - close.shift(1)).abs(),
    ], axis=1).max(axis=1)
    for p in [7, 14, 21]:
        df[f"atr_{p}_pct"] = tr.rolling(p).mean() / close

    # Volume ratios
    for p in [5, 10, 20]:
        vsma = vol.rolling(p).mean()
        df[f"volume_ratio_{p}"] = vol / vsma.replace(0, np.nan)
    obv     = (np.sign(close.diff()) * vol).fillna(0).cumsum()
    obv_ema = obv.ewm(span=20).mean()
    df["obv_ema_slope"] = obv_ema.diff(5) / (obv_ema.abs() + 1e-9)

    # Statistical moments
    ret = close.pct_change()
    for p in [20, 60]:
        mu, sd = ret.rolling(p).mean(), ret.rolling(p).std()
        df[f"zscore_{p}"]   = (ret - mu) / sd
        df[f"ret_skew_{p}"] = ret.rolling(p).skew()
        df[f"ret_kurt_{p}"] = ret.rolling(p).kurt()

    # Trend / channel
    df["channel_pos"]      = ((close - low.rolling(20).min()) /
                               (high.rolling(20).max() - low.rolling(20).min()))
    df["dist_52w_high"]    = close / high.rolling(252).max() - 1
    df["dist_52w_low"]     = close / low.rolling(252).min()  - 1
    df["sma_cross_50_200"] = close.rolling(50).mean() / close.rolling(200).mean() - 1
    df["ema_cross_12_26"]  = close.ewm(span=12).mean() / close.ewm(span=26).mean() - 1

    # Rolling volatility
    for p in [5, 10, 20, 60]:
        df[f"vol_{p}d"] = ret.rolling(p).std() * np.sqrt(252)

    return df.replace([np.inf, -np.inf], np.nan)


def calculate_macro_features(macro_data: dict) -> dict:
    """Extract the latest scalar from each macro indicator series."""
    def _last(ticker):
        d = macro_data.get(ticker)
        if d is None or d.empty:
            return 0.0
        s = d["Close"].squeeze().dropna()
        return float(s.iloc[-1]) if not s.empty else 0.0

    m = {
        "vix": _last("^VIX"), "yield_10y": _last("^TNX"),
        "yield_5y": _last("^FVX"), "yield_3m": _last("^IRX"),
        "dxy": _last("DX=F"),
        "vix_change": 0.0, "yield_curve_5_10": 0.0, "yield_10y_roc20": 0.0,
        "credit_spread": 0.0, "btc_momentum": 0.0,
        "XLE_momentum": 0.0, "XLF_momentum": 0.0, "XLK_momentum": 0.0,
    }

    if "^VIX" in macro_data:
        s = macro_data["^VIX"]["Close"].squeeze().dropna()
        if len(s) > 1:
            m["vix_change"] = float(s.pct_change().iloc[-1])

    if m["yield_5y"] and m["yield_10y"]:
        m["yield_curve_5_10"] = m["yield_5y"] - m["yield_10y"]

    if "^TNX" in macro_data:
        s = macro_data["^TNX"]["Close"].squeeze().dropna()
        if len(s) > 20:
            m["yield_10y_roc20"] = float(s.pct_change(20).iloc[-1])

    if "HYG" in macro_data and "LQD" in macro_data:
        hyg = macro_data["HYG"]["Close"].squeeze().dropna()
        lqd = macro_data["LQD"]["Close"].squeeze().dropna()
        if len(hyg) > 20 and len(lqd) > 20:
            m["credit_spread"] = float(
                hyg.pct_change(20).iloc[-1] - lqd.pct_change(20).iloc[-1])

    for sec in ["XLE", "XLF", "XLK"]:
        if sec in macro_data:
            s = macro_data[sec]["Close"].squeeze().dropna()
            if len(s) > 20:
                m[f"{sec}_momentum"] = float(s.pct_change(20).iloc[-1])

    if "BTC-USD" in macro_data:
        s = macro_data["BTC-USD"]["Close"].squeeze().dropna()
        if len(s) > 20:
            m["btc_momentum"] = float(s.pct_change(20).iloc[-1])

    return {k: (v if np.isfinite(v) else 0.0) for k, v in m.items()}


# ============================================================
# SECTION E: REGIME DETECTION (3-state Markov Switching)
# ============================================================

def fit_regime_model(returns: pd.Series) -> pd.DataFrame:
    """
    Fits 3-state Markov-switching model (switching mean + variance).
    Post-sorts regimes by estimated mean return:
      0 = Bull (highest mean), 1 = Neutral, 2 = Bear (lowest mean).
    Falls back to volatility-tertile clustering on failure.
    """
    r   = (returns.dropna() * 100).values
    idx = returns.dropna().index

    try:
        if len(r) < 150:
            raise ValueError("Insufficient observations for 3-state model")

        model = MarkovRegression(r, k_regimes=N_REGIMES,
                                 switching_variance=True,
                                 switching_trend=False)
        res   = model.fit(disp=False, maxiter=200,
                          warn_convergence=False, em_iter=10)

        pix        = list(res.params.index)
        const_keys = [k for k in pix if "const"  in str(k).lower()][:N_REGIMES]
        sig_keys   = [k for k in pix if "sigma2" in str(k).lower()][:N_REGIMES]

        means = []
        for k in const_keys:
            try:    means.append(float(res.params[k]))
            except: means.append(0.0)
        while len(means) < N_REGIMES:
            means.append(0.0)

        fvol = float(returns.std())
        vols_raw = []
        for k in sig_keys:
            try:
                v = float(np.sqrt(abs(res.params[k])) / 100)
                vols_raw.append(v if (np.isfinite(v) and v > 0) else fvol)
            except:
                vols_raw.append(fvol)
        while len(vols_raw) < N_REGIMES:
            vols_raw.append(fvol)

        order      = list(np.argsort(means)[::-1])   # highest mean = regime 0
        old_to_new = {old: new for new, old in enumerate(order)}

        raw_probs  = res.smoothed_marginal_probabilities
        out        = pd.DataFrame(index=idx)
        for old_i, new_i in old_to_new.items():
            out[f"regime_{new_i}_prob"] = raw_probs[old_i].values
            out[f"regime_{new_i}_vol"]  = vols_raw[old_i]

        out["regime_current"] = (
            out[[f"regime_{i}_prob" for i in range(N_REGIMES)]]
            .idxmax(axis=1).str.extract(r"(\d+)")[0].astype(int)
        )
        return out

    except Exception:
        # Fallback: volatility-percentile tertiles, then relabel by mean return
        vol_20     = returns.rolling(20).std()
        p33, p67   = vol_20.quantile(0.33), vol_20.quantile(0.67)
        raw        = pd.cut(vol_20, bins=[-np.inf, p33, p67, np.inf],
                            labels=[0, 1, 2]).astype(float)
        means_fb   = {i: float(returns[raw == i].mean())
                      for i in range(N_REGIMES) if (raw == i).any()}
        order_fb   = sorted(means_fb, key=means_fb.get, reverse=True)
        remap      = {old: new for new, old in enumerate(order_fb)}
        mapped     = raw.map(lambda x: remap.get(int(x), 1) if not pd.isna(x) else 1)

        out = pd.DataFrame({"regime_current": mapped}, index=returns.index)
        for new_i in range(N_REGIMES):
            mask = (mapped == new_i)
            out[f"regime_{new_i}_prob"] = mask.astype(float)
            out[f"regime_{new_i}_vol"]  = float(
                returns[mask].std() if mask.any() else returns.std())
        return out


# ============================================================
# SECTION F: VOLATILITY FORECASTING
# ============================================================

def forecast_volatility(returns_series: pd.Series) -> float:
    """
    Fits GARCH(1,1), EGARCH(1,1), GJR-GARCH(1,1,1) all with Student-t.
    Picks lowest AIC.  Returns daily vol as a fraction.
    """
    series = returns_series.dropna() * 100
    if len(series) < 50:
        return float(series.std() / 100)

    fitted = []
    for spec in [
        dict(vol="Garch",  p=1, q=1,      dist="t"),
        dict(vol="EGARCH", p=1, q=1,      dist="t"),
        dict(vol="Garch",  p=1, o=1, q=1, dist="t"),
    ]:
        try:
            res = arch_model(series, rescale=False, **spec).fit(
                disp="off", show_warning=False)
            fitted.append(res)
        except Exception:
            pass

    if not fitted:
        return float(series.std() / 100)

    best  = min(fitted, key=lambda r: r.aic)
    fcast = best.forecast(horizon=1)
    sigma = float(np.sqrt(fcast.variance.values[-1, 0]) / 100)
    return sigma if (np.isfinite(sigma) and sigma > 0) else float(series.std() / 100)


# ============================================================
# SECTION G: DRIFT CALCULATION
# ============================================================

def _safe_float(x, default: float = 0.0) -> float:
    if isinstance(x, pd.Series):
        x = x.iloc[0]
    try:
        v = float(x)
        return v if np.isfinite(v) else default
    except Exception:
        return default


def calculate_drift(symbol: str, returns_series: pd.Series,
                    interest_rates: dict,
                    rsi_14: float, bb_position: float) -> dict:
    """
    Combines carry (interest differential), momentum, RSI mean-reversion,
    and BB mean-reversion into a total daily drift estimate.
    Sentiment is excluded from drift and used only in composite ranking.
    """
    ccy      = ASSET_TO_CCY.get(symbol, "USD")
    usd_rate = interest_rates.get("USD", 0.0)
    ccy_rate = interest_rates.get(ccy, usd_rate)

    carry = (ccy_rate - usd_rate) / 100.0 / 252.0
    if symbol in USD_BASE_PAIRS:
        carry = -carry

    r      = returns_series.dropna()
    mom_5  = _safe_float(r.tail(5).mean())  if len(r) >= 5  else 0.0
    mom_20 = _safe_float(r.tail(20).mean()) if len(r) >= 20 else 0.0
    mom_60 = _safe_float(r.tail(60).mean()) if len(r) >= 60 else 0.0
    momentum = (mom_5 * 0.5 + mom_20 * 0.3 + mom_60 * 0.2) * 0.1

    rsi_signal = -0.0001 if rsi_14 > 70 else (0.0001 if rsi_14 < 30 else 0.0)
    bb_signal  = -(bb_position - 0.5) * 0.0001

    total = carry * 0.40 + momentum * 0.35 + rsi_signal * 0.125 + bb_signal * 0.125
    return {"carry": carry, "momentum": momentum,
            "rsi": rsi_signal, "bb": bb_signal, "total": total}


# ============================================================
# SECTION H: MONTE CARLO SIMULATION
# ============================================================

def simulate_prices(P0: float, drift: float, vol: float,
                    days: int = 1, trials: int = 3000,
                    jump_prob: float = 0.02,
                    jump_mean: float = 0.0,
                    jump_std:  float = 0.025) -> np.ndarray:
    """
    GBM with Student-t(5) innovations and Poisson jump diffusion.
    np.random.seed() must be set once by the caller; never reset here.
    """
    P0    = _safe_float(P0)
    drift = _safe_float(drift)
    vol   = max(_safe_float(vol, 0.01), 1e-6)

    prices = np.full(trials, P0, dtype=np.float64)
    for _ in range(days):
        eps   = stats.t.rvs(df=5, size=trials) / np.sqrt(5.0 / 3.0)
        jumps = np.where(np.random.rand(trials) < jump_prob,
                         np.random.normal(jump_mean, jump_std, trials), 0.0)
        prices *= np.exp((drift - 0.5 * vol**2) + vol * eps + jumps)
    return prices


def run_monte_carlo(current_price: float, drift: float, vol: float) -> dict:
    """Runs MC across MC_HORIZONS; returns stats dict keyed by horizon name."""
    out = {}
    for h_name, days in MC_HORIZONS.items():
        finals  = simulate_prices(current_price, drift, vol,
                                  days=days, trials=MC_TRIALS)
        ret_pct = (finals / current_price - 1.0) * 100.0
        p5      = float(np.percentile(ret_pct, 5))
        tail    = ret_pct[ret_pct <= p5]
        cvar    = float(-np.mean(tail)) if len(tail) > 0 else float(-p5)

        out[h_name] = {
            "mean_return":    float(np.mean(ret_pct)),
            "median_return":  float(np.median(ret_pct)),
            "std_return":     float(np.std(ret_pct)),
            "skew":           float(stats.skew(ret_pct)),
            "kurtosis":       float(stats.kurtosis(ret_pct)),
            "p5": p5, "p25": float(np.percentile(ret_pct, 25)),
            "p75": float(np.percentile(ret_pct, 75)),
            "p95": float(np.percentile(ret_pct, 95)),
            "VaR_95":         float(-p5),
            "CVaR_95":        cvar,
            "prob_up":        float(np.mean(finals > current_price)),
            "expected_price": float(np.mean(finals)),
            "range_low_1s":   float(np.percentile(finals, 16)),
            "range_high_1s":  float(np.percentile(finals, 84)),
            "ret_array":      ret_pct,   # retained for Sortino/Omega
        }
    return out


# ============================================================
# SECTION I: MACHINE LEARNING ENSEMBLE -- LEAKAGE-FREE
# ============================================================

def _fold_impute(X_tr: np.ndarray, X_va: np.ndarray):
    """
    Computes column medians on training data only, applies to both folds.
    Eliminates imputation leakage: val-set statistics never touch training.
    Returns (X_tr_imputed, X_va_imputed, col_medians).
    """
    medians = np.nanmedian(X_tr, axis=0)
    for j in range(X_tr.shape[1]):
        X_tr[np.isnan(X_tr[:, j]), j] = medians[j]
        X_va[np.isnan(X_va[:, j]), j] = medians[j]
    return X_tr, X_va, medians


def train_ml_ensemble(X: pd.DataFrame, y: pd.Series) -> dict:
    """
    Leakage-free training:
      1. TimeSeriesSplit folds: inside each fold, fit RobustScaler and
         median imputer on train only, transform both train and val.
      2. CV accuracy scores are unbiased estimates.
      3. After CV, refit scaler + imputer on full data for live inference.

    Returns: scaler, col_medians, best_model, cv_score, all_scores,
             feature_cols (for column-alignment in predict_with_model).
    """
    X_arr  = X.values.copy().astype(np.float64)
    y_arr  = y.values
    cols   = list(X.columns)
    tscv   = TimeSeriesSplit(n_splits=5)

    specs = {
        "LR":  LogisticRegression(max_iter=2000, C=0.1,
                                   class_weight="balanced", random_state=SEED),
        "RF":  RandomForestClassifier(n_estimators=200, max_depth=12,
                                       min_samples_split=15,
                                       class_weight="balanced",
                                       n_jobs=-1, random_state=SEED),
        "GB":  GradientBoostingClassifier(n_estimators=150, max_depth=4,
                                           learning_rate=0.05, subsample=0.8,
                                           random_state=SEED),
        "XGB": xgb.XGBClassifier(n_estimators=150, max_depth=5,
                                   learning_rate=0.05, subsample=0.8,
                                   eval_metric="logloss",
                                   random_state=SEED, verbosity=0),
        "LGB": lgb.LGBMClassifier(n_estimators=150, max_depth=5,
                                    learning_rate=0.05, subsample=0.8,
                                    random_state=SEED, verbose=-1),
    }

    cv_scores = {name: [] for name in specs}

    for tr_idx, va_idx in tscv.split(X_arr):
        X_tr, X_va = X_arr[tr_idx].copy(), X_arr[va_idx].copy()
        y_tr, y_va = y_arr[tr_idx],         y_arr[va_idx]

        # Impute and scale inside fold -- no leakage
        X_tr, X_va, _ = _fold_impute(X_tr, X_va)
        sc_fold        = RobustScaler()
        X_tr           = sc_fold.fit_transform(X_tr)
        X_va           = sc_fold.transform(X_va)

        for name, model in specs.items():
            try:
                model.fit(X_tr, y_tr)
                cv_scores[name].append(
                    accuracy_score(y_va, model.predict(X_va)))
            except Exception:
                pass

    mean_scores = {n: float(np.mean(v)) for n, v in cv_scores.items() if v}
    if not mean_scores:
        return {}

    # -- Fit final pipeline on full dataset ----------------------------------------
    X_full   = X_arr.copy()
    medians  = np.nanmedian(X_full, axis=0)
    for j in range(X_full.shape[1]):
        X_full[np.isnan(X_full[:, j]), j] = medians[j]

    final_sc = RobustScaler()
    X_sc     = final_sc.fit_transform(X_full)

    trained = {}
    for name, model in specs.items():
        if name in mean_scores:
            try:
                model.fit(X_sc, y_arr)
                trained[name] = model
            except Exception:
                pass

    if len(trained) >= 3:
        try:
            ens = VotingClassifier(estimators=list(trained.items()), voting="soft")
            ens.fit(X_sc, y_arr)
            trained["ENSEMBLE"] = ens
            mean_scores["ENSEMBLE"] = float(max(mean_scores.values()) + 0.005)
        except Exception:
            pass

    best_name = max(mean_scores, key=mean_scores.get)
    return {
        "scaler":       final_sc,
        "col_medians":  medians,
        "best_model":   trained.get(best_name),
        "best_name":    best_name,
        "cv_score":     mean_scores[best_name],
        "all_scores":   mean_scores,
        "feature_cols": cols,
    }


def predict_with_model(ml_result: dict, X_latest: pd.DataFrame) -> float:
    """
    Applies training-fitted imputer -> scaler -> predict_proba to one row.
    Column alignment ensures the live observation matches training features.
    Returns P(bullish) as a float in [0, 1].
    """
    if not ml_result or ml_result.get("best_model") is None:
        return 0.5

    cols     = ml_result["feature_cols"]
    medians  = ml_result["col_medians"]
    scaler   = ml_result["scaler"]
    model    = ml_result["best_model"]

    row = X_latest.reindex(columns=cols).values.astype(np.float64).flatten()
    for j in range(len(row)):
        if np.isnan(row[j]):
            row[j] = medians[j] if j < len(medians) else 0.0

    proba = model.predict_proba(scaler.transform(row.reshape(1, -1)))[0]
    return float(proba[1])


# ============================================================
# SECTION J: RANKING UTILITIES
# ============================================================

def _sharpe(mean_r: float, std_r: float) -> float:
    return mean_r / std_r if std_r > 0 else 0.0

def _sortino(ret_array: np.ndarray, target: float = 0.0) -> float:
    dd = ret_array[ret_array < target]
    ds = float(np.std(dd)) if len(dd) > 1 else 1e-9
    return (float(np.mean(ret_array)) - target) / ds if ds > 0 else 0.0

def _omega(ret_array: np.ndarray, threshold: float = 0.0) -> float:
    gains  = ret_array[ret_array >  threshold] - threshold
    losses = threshold - ret_array[ret_array <= threshold]
    if losses.sum() == 0:
        return 10.0      # cap at 10 to keep z-scoring well-behaved
    if gains.sum() == 0:
        return 0.0
    return float(min(gains.sum() / losses.sum(), 10.0))


# ============================================================
# SECTION K: BACKTEST LOGGER WITH LIVE BACKFILL
# ============================================================

def _write_backtest_log(results: dict, asset_data: dict):
    """
    1. Loads existing backtest CSV (if any).
    2. For every past forecast row where realized_return_1w is blank
       AND BT_HORIZON trading days have elapsed, pulls the actual
       close-to-close return from asset_data already in memory,
       computes MAE and direction correctness, and fills them in.
    3. Appends today's new forecasts (realized fields left blank).
    4. Saves deduplicated, sorted CSV.
    5. Prints walk-forward accuracy summary when enough data exists.

    This runs automatically on every execution -- no separate backfill
    script is needed.
    """
    today_str = str(pd.Timestamp.utcnow().normalize().date())

    new_rows = []
    for sym, r in results.items():
        new_rows.append({
            "date":               today_str,
            "symbol":             sym,
            "asset_class":        r["asset_class"],
            "forecast_dir":       r["mc_direction"],
            "forecast_return_1w": r["mc_return_1w"],
            "forecast_vol_daily": r["final_vol_daily"],
            "forecast_sharpe":    r["sharpe_1w"],
            "composite_score":    r["composite_score"],
            "realized_return_1w": np.nan,
            "forecast_error":     np.nan,
            "direction_correct":  np.nan,
        })
    new_df = pd.DataFrame(new_rows)

    try:
        log = pd.read_csv(BT_FILE, parse_dates=["date"])
    except FileNotFoundError:
        log = pd.DataFrame()

    # -- Backfill realised returns for mature past forecasts -------------------
    if not log.empty and "date" in log.columns:
        log["date"]      = pd.to_datetime(log["date"])
        today_ts         = pd.Timestamp.utcnow().normalize()
        unfilled_mask    = log["realized_return_1w"].isna()

        for idx in log.index[unfilled_mask]:
            sym   = log.at[idx, "symbol"]
            f_dt  = pd.Timestamp(log.at[idx, "date"])
            elapsed_days = (today_ts - f_dt).days

            # Need at least BT_HORIZON+2 calendar days before backfilling
            # (accounts for weekends; 5 trading days ~ 7 calendar days)
            if elapsed_days < BT_HORIZON + 2:
                continue
            if sym not in asset_data:
                continue

            close = asset_data[sym]["Close"].squeeze().dropna()
            close.index = pd.to_datetime(close.index).tz_localize(None)
            f_dt_naive  = f_dt.tz_localize(None)

            # Find the first available price on or after the forecast date
            future = close[close.index >= f_dt_naive]
            if len(future) < BT_HORIZON + 1:
                continue

            p_entry  = float(future.iloc[0])
            p_exit   = float(future.iloc[BT_HORIZON])
            realized = (p_exit / p_entry - 1.0) * 100.0
            real_dir = "BULLISH" if realized > 0 else "BEARISH"
            f_ret    = log.at[idx, "forecast_return_1w"]

            log.at[idx, "realized_return_1w"] = round(realized, 4)
            log.at[idx, "forecast_error"]     = round(
                abs(realized - f_ret) if pd.notna(f_ret) else np.nan, 4)
            log.at[idx, "direction_correct"]  = int(
                real_dir == log.at[idx, "forecast_dir"])

    # -- Append today and save -------------------------------------------------
    log = pd.concat([log, new_df], ignore_index=True)
    log["date"] = pd.to_datetime(log["date"])
    log = (log.drop_duplicates(subset=["date", "symbol"], keep="last")
              .sort_values(["symbol", "date"])
              .reset_index(drop=True))
    log.to_csv(BT_FILE, index=False)

    # -- Walk-forward accuracy summary -----------------------------------------
    filled = log.dropna(subset=["realized_return_1w", "forecast_return_1w",
                                 "direction_correct"])
    n = len(filled)
    print(f"\n  Backtest log: {len(log)} entries total, {n} with realised returns")
    if n >= 5:
        mae     = float(filled["forecast_error"].mean())
        rmse    = float(np.sqrt((filled["forecast_error"]**2).mean()))
        dir_acc = float(filled["direction_correct"].mean())
        print(f"  Walk-forward accuracy ({n} completed forecasts):")
        print(f"    Direction accuracy : {dir_acc:.1%}")
        print(f"    MAE  (return %)    : {mae:.2f}%")
        print(f"    RMSE (return %)    : {rmse:.2f}%")
        per_asset = (filled.groupby("symbol")
                     .agg(n=("direction_correct", "count"),
                          dir_acc=("direction_correct", "mean"),
                          mae=("forecast_error", "mean"))
                     .sort_values("dir_acc", ascending=False))
        print(f"\n  Per-asset accuracy:\n{per_asset.to_string()}")
    else:
        print(f"  (need >= 5 completed forecasts to report accuracy; have {n})")



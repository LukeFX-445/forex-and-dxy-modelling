def fetch_news_sentiments() -> dict:
    """
    VADER-scores FXStreet RSS articles against CB keywords.
    Returns mean compound sentiment per currency [-1, +1].
    Used as a cross-sectional ranking signal, not as raw drift.
    """
    try:
        entries = feedparser.parse("https://www.fxstreet.com/rss/news").entries[:100]
    except Exception:
        return {ccy: 0.0 for ccy in CB_KEYWORDS}

    analyzer = SentimentIntensityAnalyzer()
    scores   = {ccy: [] for ccy in CB_KEYWORDS}

    for entry in entries:
        text = f"{entry.get('title', '')}. {entry.get('summary', '')}"
        for ccy, kws in CB_KEYWORDS.items():
            if any(kw.lower() in text.lower() for kw in kws):
                scores[ccy].append(analyzer.polarity_scores(text)["compound"])

    return {ccy: float(np.mean(v)) if v else 0.0 for ccy, v in scores.items()}


